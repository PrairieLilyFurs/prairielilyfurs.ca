---
import type { IEvent } from "./EventList.astro";
const { data } = Astro.props as { data: IEvent };
const Content = data.Content;
---
<section>
    <header>
    <h5>{data.title}</h5>
    <time datetime={data.date.toISOString()}>
        {data.date.toLocaleString("en-CA", {
        dateStyle: "long",
        timeStyle: "short",
        timeZone: "America/Regina",
        })}
    </time>
    </header>
    {Content && <Content />}
</section>
